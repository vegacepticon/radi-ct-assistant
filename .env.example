# RadiCT Assistant local configuration
# Hermes-only mode: this backend does not call external LLM APIs.
# Hermes generates assistant_draft in Telegram/agent context and stores it via /api/draft.

# --- Embedding ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Paths ---
REFERENCES_DIR=data/references
INDEX_DIR=data/index

# --- Retrieval ---
TOP_K=5
MIN_SIMILARITY=0.5


# --- Server ---
HOST=0.0.0.0
PORT=8420